// Task modeli — docs/PRD.md §5 ve docs/ARCHITECTURE.md (Veri Modeli) ile
// birebir uyumludur. Bu iterasyonda sadece Feature 001 (Görev Oluştur,
// docs/specs/001-todo-olustur.md) kapsamındaki alanlar kullanılıyor;
// Subtask/Tag modelleri henüz hiçbir endpoint tarafından kullanılmadığı
// için kapsam dışı bırakıldı — ileride ilgili feature spec'leri
// yazıldığında eklenecek.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  low
  medium
  high
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  completed   Boolean   @default(false)
  priority    Priority  @default(medium)
  dueDate     DateTime? @db.Date
  order       Float
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("tasks")
}
